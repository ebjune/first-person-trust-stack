{
  "name": "fpts-exploratory",
  "private": true,
  "version": "0.1.0",
  "description": "First Person Trust Stack — PNM/CNM/VTN UX, governance plane, and VTI adapters (fpndtg.com)",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r --parallel run dev",
    "dev:web": "pnpm --filter @fpndtg/web dev",
    "dev:validator": "pnpm --filter @fpndtg/validator dev",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "db:generate": "pnpm --filter @fpndtg/db-infra db:generate && pnpm --filter @fpndtg/db-user db:generate",
    "db:migrate": "pnpm --filter @fpndtg/db-infra db:migrate && pnpm --filter @fpndtg/db-user db:migrate",
    "db:migrate:deploy": "pnpm --filter @fpndtg/db-infra db:migrate:deploy && pnpm --filter @fpndtg/db-user db:migrate:deploy"
  }
}
