# ============================================================
# First Person Trust Stack — Environment Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.
# ============================================================

# ------------------------------------------------------------
# Database connections (Ubuntu Postgres server)
# Two separate databases — see docs/DATABASE-SETUP.md
# ------------------------------------------------------------
# Individual fields (used to construct URLs below)
DB_HOST=REPLACE_WITH_DB_HOST
DB_PORT=REPLACE_WITH_DB_PORT (typically 5432)
DB_USER=REPLACE_WITH_DB_USER
DB_PASSWORD=REPLACE_WITH_DB_USER_PASSWORD

# Constructed connection URLs for Prisma
DATABASE_INFRA_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/fps_infra
DATABASE_USER_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/fps_user

# ------------------------------------------------------------
# VTI endpoints (brand-config defaults; override for local dev)
# ------------------------------------------------------------
# FPNDTG_VTA_URL=https://vta.fpndtg.com
# FPNDTG_VTC_URL=https://vtc.fpndtg.com
# FPNDTG_DIDS_URL=https://dids.fpndtg.com

# ------------------------------------------------------------
# Auth service (services/auth-service)
# ------------------------------------------------------------
AUTH_SERVICE_PORT=8788
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SESSION_SECRET=REPLACE_WITH_RANDOM_32_BYTE_HEX
AUTH_CHALLENGE_TTL_SECONDS=300

# ------------------------------------------------------------
# Sync service (services/sync-service)
# ------------------------------------------------------------
SYNC_SERVICE_ENABLED=true
SYNC_SERVICE_POLL_INTERVAL_MS=1000

# ------------------------------------------------------------
# Validator (apps/validator)
# ------------------------------------------------------------
# PORT=8787
